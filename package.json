{
  "name": "contact-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server.js",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "build": "npm run check:i18n && vite build",
    "typecheck": "tsc -b",
    "lint": "npm run check:i18n && eslint .",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server.js",
    "db:migrate": "node-pg-migrate up -d DATABASE_URL -m db/migrations --migration-file-language sql",
    "db:migrate:down": "node-pg-migrate down -d DATABASE_URL -m db/migrations --migration-file-language sql",
    "db:seed": "node db/seed.js",
    "db:reset": "node-pg-migrate down -d DATABASE_URL -m db/migrations --migration-file-language sql --count 999 && npm run db:migrate && npm run db:seed",
    "db:status": "node scripts/migration-status.mjs",
    "db:reset:soft": "node-pg-migrate down -d DATABASE_URL -m db/migrations --migration-file-language sql --count 999 && npm run db:migrate",
    "db:create": "node scripts/create-migration.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@tanstack/react-query": "^5.56.2",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "i18next": "^25.10.9",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.462.0",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^16.3.2",
    "file-type": "^19.6.0",
    "multer": "^1.4.5-lts.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.13.3",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc-1",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.5.0",
    "vite": "^6.3.4"
  },
  "overrides": {
    "tar": "^7.5.16",
    "glob": "^11.1.0",
    "@mapbox/node-pre-gyp": "^2.0.0"
  }
}
