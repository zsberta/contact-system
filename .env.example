# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgres://contact:contact_pw@localhost:5432/contact_system
DATABASE_SSL=false

# --- Auth secrets ---
JWT_SECRET=replace_with_openssl_rand_hex_64
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
BCRYPT_COST=12

# --- Admin seed (used by `npm run db:seed`) ---
# IMPORTANT: ADMIN_PASSWORD must be ≥ 12 chars and NOT in the deny-list
# (changeme, admin, password, 12345678, qwerty, letmein).
# In production (NODE_ENV=production) it must be ≥ 16 chars or the server refuses to start.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# --- Cookies ---
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=Lax

# --- Rate limits ---
# All limits are intentionally generous (thousands+) so E2E + load tests
# don't hit walls. Real security is still enforced by:
#   - bcrypt cost (12) + dummy-hash timing on /signin (defeats online brute-force)
#   - JWT signature verification on every request
#   - /forgot-password is always-200 (no email enumeration via response shape)
#   - /set-password is token-gated (the token IS the capability)
#   - /refresh is JWT-bound (an attacker can't refresh without a valid signed JWT)
# All limits are in-process and per-IP (req.ip).

# Global catch-all on /api/*. Default 10000 per minute.
API_GLOBAL_LIMIT=10000

# Per-IP signin attempts on POST /api/auth/signin. Default 5000 per 15 min.
SIGNIN_LIMIT=5000
# Per-IP refresh on POST /api/auth/refresh. Default 10000 per minute.
REFRESH_LIMIT=10000
# Per-IP forgot-password on POST /api/auth/forgot-password + reset-password. Default 5000 per 15 min.
FORGOT_LIMIT=5000
# Per-IP set-password on POST /api/auth/set-password. Default 5000 per 15 min. Token-gated.
SET_PASSWORD_LIMIT=5000

# --- Forms (public submission rate limits) ---
# Per-IP burst on POST /api/public/forms/:secret_token/submissions. Default 10000 per minute.
PUBLIC_FORM_SUBMISSION_BURST_LIMIT=10000
# Per-IP sustained on POST /api/public/forms/:secret_token/submissions. Default 100000 per 24h.
PUBLIC_FORM_SUBMISSION_SUSTAINED_LIMIT=100000

# --- Reservations (public booking rate limits) ---
# Per-IP burst on POST /api/public/reservations/:token/bookings. Default 10000 per minute.
PUBLIC_RESERVATION_BOOKING_BURST_LIMIT=10000
# Per-IP burst on GET /api/public/reservations/:token/availability. Default 20000 per minute.
PUBLIC_RESERVATION_AVAILABILITY_BURST_LIMIT=20000
# Per-IP sustained on POST /api/public/reservations/:token/bookings. Default 100000 per 24h.
PUBLIC_RESERVATION_SUSTAINED_LIMIT=100000

# --- Analytics (public event collection rate limits) ---
# Per-IP burst on POST /api/public/analytics/:token/collect. Default 10000 per minute.
# The JS loader issues one POST per pageview and (optionally) one per custom
# event. Each landing page with the snippet burns at most 1-2 hits per
# navigation; 10000/min is a 100x safety margin for typical traffic.
PUBLIC_ANALYTICS_COLLECT_BURST_LIMIT=10000
# Per-IP sustained on POST /api/public/analytics/:token/collect. Default 100000 per 24h.
PUBLIC_ANALYTICS_COLLECT_SUSTAINED_LIMIT=100000

# --- Email queue (rate limit + retry for outgoing SMTP) ---
# Token bucket: refill rate is one token per EMAIL_QUEUE_INTERVAL_MS.
# Burst capacity is EMAIL_QUEUE_BURST — the most sends that can fire
# at once when the bucket is full. After the burst drains, sends are
# paced at one per EMAIL_QUEUE_INTERVAL_MS.
#
# Default: burst 5, 1 send per 1s. A form submission triggers two
# notifications (operator + submitter auto-reply) so 5 burst handles
# 2-3 simultaneous submissions comfortably before throttling kicks in.
# The 1s refill is well within Larksuite's generous quota; tune up if
# your SMTP provider complains, down for snappier notifications on
# low traffic.
EMAIL_QUEUE_BURST=5
EMAIL_QUEUE_INTERVAL_MS=1000
# Max attempts per message (initial + retries). 3 = initial + 2 retries.
EMAIL_QUEUE_MAX_ATTEMPTS=3
# Time the worker will wait for in-flight jobs to finish on SIGTERM
# before giving up and exiting. Must be < docker stop_grace_period
# (default 10s) so the worker exits cleanly before SIGKILL.
EMAIL_QUEUE_SHUTDOWN_TIMEOUT_MS=8000

# --- Email / SMTP (enduser invite + forgot-password + submission notifications) ---
# Leave SMTP_HOST empty to use the dev JSON transport. In that mode the
# invite/reset links (and submission notification bodies) are LOGGED TO
# STDOUT (look for "[email/dev-json]") instead of being sent over the
# network. Convenient for development; do NOT use in production.
#
# Production: this project emails form submissions and reservation
# bookings to each project's `customer_email` (set on the Projects page).
# Sender is `info@zsoltberta.hu` via Larksuite SMTP (smtp.larksuite.com,
# implicit TLS on port 465). The real credentials live in .env — do NOT
# commit them. The block below mirrors the Larksuite wiring with empty
# values so a fresh checkout doesn't accidentally point at prod creds.
SMTP_HOST=
SMTP_PORT=465
# Set to "true" for implicit TLS (port 465 typically). For STARTTLS (587)
# leave as "false" and rely on the server's opportunistic STARTTLS.
SMTP_SECURE=true
# When your SMTP server requires auth, fill these in. Empty = no auth.
SMTP_USER=
SMTP_PASSWORD=
# For self-signed certs in dev, you can disable certificate validation.
# In production this MUST be "true" (the default) — set to "false" only
# behind a known local CA that the container doesn't trust.
SMTP_REJECT_UNAUTHORIZED=true
# From address shown in the email. Falls back to ADMIN_EMAIL.
# SMTP_FROM is the BARE envelope address (no display-name wrapper).
# The display name is set per-call by sendMail({ fromName }) — the
# operator notification uses "Zsolt CRM rendszere" and the submitter
# auto-reply uses the project name, so the env value just carries
# the actual mailbox the SMTP provider should send from.
SMTP_FROM=info@zsoltberta.hu

# --- Public origin for invite/reset email links ---
# This is the URL the recipient sees in their email's "Click here" link.
# MUST be set in production (otherwise the link will point to the
# internal docker hostname, which the enduser can't reach). In dev
# we fall back to the request host, which is good enough for localhost.
# Example: APP_PUBLIC_URL=https://crm.example.com
APP_PUBLIC_URL=
