NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://contact:6c054e724fa93b0da6b996f66bd29b3b@localhost:5432/contact_system
DATABASE_SSL=false

JWT_SECRET=
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
BCRYPT_COST=12

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=Lax
POSTGRES_PASSWORD=

# --- Email / SMTP (form submission + reservation booking notifications) ---
# Recipient for notification emails is the project's customer_email column
# (look it up in the Projects admin page). SMTP via Larksuite (zsoltberta.hu).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_REJECT_UNAUTHORIZED=true
SMTP_FROM=info@zsoltberta.hu

# --- Email queue (rate limit + retry for outgoing SMTP) ---
# Refill 1 token / 1s. Generous SMTP provider, so the queue paces
# notifications at human-perceived speed without bursting.
EMAIL_QUEUE_BURST=5
EMAIL_QUEUE_INTERVAL_MS=1000
EMAIL_QUEUE_MAX_ATTEMPTS=3
EMAIL_QUEUE_SHUTDOWN_TIMEOUT_MS=8000

APP_PUBLIC_URL=
